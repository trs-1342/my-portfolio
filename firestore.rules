rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı profilleri
    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      allow delete: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Username → uid haritası
    match /usernames/{username} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // İletişim formu mesajları
    match /contacts/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Site konfigürasyonu (hero, skills, menu vb.)
    match /site_config/{doc} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Projeler
    match /projects/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // HSounds makaleleri
    match /hsounds_articles/{docId} {
      allow read: if true;
      // Admin tam yazma hakkı
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
      // Admin her alanı güncelleyebilir; giriş yapan kullanıcılar sadece likes alanını güncelleyebilir
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes"])
      );
    }

    // Yorumlar
    match /comments/{commentId} {
      allow read: if true;
      // Sadece giriş yapan kullanıcılar yorum yazabilir, kendi UID'leriyle
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid;
      // Giriş yapanlar sadece likes alanını güncelleyebilir
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likes"]);
      // Kendi yorumunu veya admin her yorumu silebilir
      allow delete: if request.auth != null && (
        resource.data.authorUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Fotoğraf galerisi
    match /photos/{docId} {
      // Sadece giriş yapanlar okuyabilir
      allow read: if request.auth != null;
      // Favori güncellemesi: giriş yapan herkes kendi UID'ini favorites array'ine ekleyip çıkarabilir
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(["favorites"]))
      );
      // Oluşturma ve silme sadece admin
      allow create, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
  }
}

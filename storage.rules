rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Fotoğraf galerisi — sadece giriş yapanlar okuyabilir, yazabilir
    match /photos/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Hakkımda fotoğrafları ve CV — herkese açık okuma, giriş yapanlar yazabilir
    match /about/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // Proje görselleri — herkese açık okuma, giriş yapanlar yazabilir
    match /projects/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

  }
}
